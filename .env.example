# ═══════════════════════════════════════════════════════════════════════════
# Configuración de Variables de Entorno — Fraud Detection Pipeline
# ═══════════════════════════════════════════════════════════════════════════
#
# INSTRUCCIONES:
# 1. Copia este archivo como `.env` en la raíz del proyecto
# 2. Personaliza los valores según tu entorno
# 3. Los scripts buscarán estas variables; si no existen, usan los defaults
#
# ═══════════════════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────────────────
# DIRECTORIOS DE DATOS
# ─────────────────────────────────────────────────────────────────────────
# Landing: donde se suben archivos CSV sin procesar
FRAUD_LANDING_DIR=data/landing

# Raw: donde se guardan CSVs después de ingestión
FRAUD_RAW_DIR=data/raw

# Processed: donde se guardan datos limpios y preparados para modelado
FRAUD_PROCESSED_DIR=data/processed

# Reports: donde se guardan reportes y métricas de evaluación
FRAUD_REPORTS_DIR=data/reports

# Models: donde se guardan modelos entrenados (.pkl)
FRAUD_MODELS_DIR=models

# ─────────────────────────────────────────────────────────────────────────
# ENTORNO DE EJECUCIÓN
# ─────────────────────────────────────────────────────────────────────────
# Valores posibles: local | staging | production
FRAUD_ENV=local

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
FRAUD_LOG_LEVEL=INFO

# ─────────────────────────────────────────────────────────────────────────
# CONFIGURACIÓN DE SEGURIDAD
# ─────────────────────────────────────────────────────────────────────────
# Claves para encriptación de datos sensibles (futuro)
# FRAUD_ENCRYPTION_KEY=your-secret-key-here

# ─────────────────────────────────────────────────────────────────────────
# PARÁMETROS DE MODELADO
# ─────────────────────────────────────────────────────────────────────────
# Número de árboles en Random Forest
FRAUD_RF_N_ESTIMATORS=200

# Profundidad máxima de los árboles
FRAUD_RF_MAX_DEPTH=15

# Estrategia de balanceo: smote | undersampling | none
FRAUD_BALANCE_STRATEGY=smote

# Proporción de SMOTE (0.15 = 15% de minority class)
FRAUD_SMOTE_RATIO=0.15

# ─────────────────────────────────────────────────────────────────────────
# BASE DE DATOS (Futuro para producción)
# ─────────────────────────────────────────────────────────────────────────
# DATABASE_URL=postgresql://user:password@localhost:5432/fraud_db
# DATABASE_POOL_SIZE=20

# ─────────────────────────────────────────────────────────────────────────
# API (Futuro para predicciones en tiempo real)
# ─────────────────────────────────────────────────────────────────────────
# FRAUD_API_HOST=0.0.0.0
# FRAUD_API_PORT=8000
# FRAUD_API_WORKERS=4

# ─────────────────────────────────────────────────────────────────────────
# ALERTAS Y MONITOREO
# ─────────────────────────────────────────────────────────────────────────
# Umbral de degradación de ROC-AUC (%)
FRAUD_ROC_AUC_THRESHOLD=0.80

# Email para alertas (futuro)
# FRAUD_ALERT_EMAIL=admin@empresa.com

# ═══════════════════════════════════════════════════════════════════════════
# NOTAS DE SEGURIDAD
# ═══════════════════════════════════════════════════════════════════════════
#
# ⚠️ IMPORTANTE:
# - NUNCA commits este archivo si contiene datos sensibles
# - Copia .env.example → .env y edita .env localmente
# - Agrega .env al .gitignore
# - En producción, usa secretos del sistema operativo o gestor de secretos
#
# Gestores de secretos recomendados:
# • AWS Secrets Manager
# • Azure Key Vault
# • HashiCorp Vault
# • 1Password Business (para equipos)
#
# ═══════════════════════════════════════════════════════════════════════════
